<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">
<!--
  Configuración básica de Checkstyle para el proyecto CSV Importer.
  Se aplican reglas sencillas que fomentan la consistencia en el código
  conforme a los principios de Clean Code.
-->
<module name="Checker">
    <module name="TreeWalker">
        <!-- Longitud máxima de línea: 120 caracteres -->
        <module name="LineLength">
            <property name="max" value="120"/>
            <property name="ignorePattern" value="^package|^import"/>
        </module>
        <!-- Longitud máxima de método: 30 líneas -->
        <module name="MethodLength">
            <property name="max" value="30"/>
        </module>
        <!-- Indentación consistente: 4 espacios -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="braceAdjustment" value="0"/>
            <property name="tabWidth" value="4"/>
        </module>
        <!-- Convenciones de nombres -->
        <module name="TypeName"/>
        <module name="ParameterName"/>
        <module name="LocalVariableName"/>
        <module name="MemberName"/>
        <module name="OuterTypeFilename"/>
    </module>
</module>